## Example environment variables for local development.
## Copy to .env and fill in real values (do not commit .env).

# GraphRAG provider credentials:
# GRAPHRAG_API_KEY=
# GRAPHRAG_EMBEDDING_API_KEY=

# API / web configuration
# CORS_ALLOW_ORIGINS=http://localhost:5173
# Or use a regex:
# CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$

# If using Docker, change query method in docker-compose.yml
# The .env file is only used for local development
# GRAPHRAG_QUERY_METHOD=
